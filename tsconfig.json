{
  "compilerOptions": {
    "rootDir": "src",
    "target": "ES2021",
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "declaration": true,
    "moduleResolution": "bundler",
    "types": ["@rstest/core/globals"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["**/node_modules"]
}
